            <img src="/images/hero_coffee.png" alt="Team 1" style="border-radius: 50%; width: 200px; height: 200px; margin: 0 auto 20px;">
            <h3>Julian Thorne</h3>
            <p>Master Roaster</p>
        </div>
        <div class="product-card">
            <img src="/images/hero_coffee.png" alt="Team 2" style="border-radius: 50%; width: 200px; height: 200px; margin: 0 auto 20px;">
            <h3>Sarah Vane</h3>
            <p>Head of Patisserie</p>
        </div>
        <div class="product-card">
            <img src="/images/hero_coffee.png" alt="Team 3" style="border-radius: 50%; width: 200px; height: 200px; margin: 0 auto 20px;">
            <h3>Marcus Lee</h3>
            <p>Coffee Sourcing</p>
        </div>
        <div class="product-card">
